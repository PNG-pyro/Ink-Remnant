[resource]
script = ExtResource("2_x8hk8")
job_name = "Research Lapidamancy"
job_desc = "You wander through the shelves, picking and browsing likely tomes. "
job_story = "The only way to judge a book is by it's cover... thankfully, they've started providing little summaries on the back. "
job_mask = Dictionary[ExtResource("1_14ft3"), int]({
ExtResource("2_jneeo"): 1
})
repeats = false
make_popup = true
popup_text = "\"Lapidamancy, from the art of lapidary, is famous for making it's practitioners rich. This isn't precisely correct, and is usually the other way around; the poor simply never have a chance to touch the threshold of this practice. There are some theories that cheaper stones could aid in practice, or other ideas. This author suggests...\""
button_text = "Done reading"
