[resource]
script = ExtResource("4_nolnp")
job_name = "Uncover the object"
job_desc = "You reach out gingerly..."
job_story = "It's a... chair?"
job_reward = Dictionary[ExtResource("1_5e3xh"), int]({
ExtResource("3_quy3r"): 1
})
job_mask = Dictionary[ExtResource("1_5e3xh"), int]({
ExtResource("2_quy3r"): 1
})
make_tooltip = false
repeats = false
make_popup = true
popup_text = "You look over the object... it's a chair, with a sheet over it. What were you getting so anxious for? You reach out and pull the sheet away. It looks a bit like a recliner, and a bit like a medical device. There are tiny silver threads woven across the dark leather, and as the light hits it, they all light up and start to glow. Following them stich by stich you find a socket in the back. This looks like it needs a power source..."
button_text = "Should you sit? Do you dare?"
